{
  "name": "crucible-cli",
  "version": "0.1.0",
  "description": "The kubectl of Azure Service Bus — CLI for message operations, DLQ management, and namespace monitoring",
  "type": "module",
  "bin": {
    "crucible": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --packages=external --jsx=automatic",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "azure",
    "service-bus",
    "servicebus",
    "cli",
    "dead-letter",
    "dlq",
    "messaging"
  ],
  "author": "Björn Rödiger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/broediger/crucible-cli.git"
  },
  "homepage": "https://github.com/broediger/crucible-cli",
  "bugs": {
    "url": "https://github.com/broediger/crucible-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "@azure/service-bus": "^7.9.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "ink": "^6.8.0",
    "node-notifier": "^10.0.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^19.2.14",
    "esbuild": "^0.25.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
